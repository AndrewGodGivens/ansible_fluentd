# Managed by Ansible
services:
  fluentd:
    image: "{{ fluentd_image }}"
    container_name: "{{ fluentd_container_name }}"
    restart: unless-stopped
    user: root
    ports:
      - "{{ fluentd_forward_bind }}:{{ fluentd_forward_port }}:24224"
      - "{{ fluentd_forward_bind }}:{{ fluentd_forward_port }}:24224/udp"
    environment:
      FLUENTD_CONF: fluentd.conf
{% for key, value in fluentd_compose_extra_env.items() %}
      {{ key }}: "{{ value }}"
{% endfor %}
    volumes:
      - "{{ fluentd_conf_path }}:/fluentd/etc/fluentd.conf:ro"
      - "/var/lib/fluentd:/var/lib/fluentd"
      # identity mounts: keep host paths used in fluentd_config (pos_file,
      # tail source path, buffer path, certs) valid unchanged inside the container
      - "{{ log_path }}:{{ log_path }}"
      - "/var/log:/var/log:ro"
      - "{{ ssl_directory_path }}:{{ ssl_directory_path }}:ro"
{% for volume in fluentd_compose_extra_volumes %}
      - "{{ volume }}"
{% endfor %}
{% if fluentd_plugins | length > 0 %}
      - "fluentd_vendor_bundle:/fluentd/vendor/bundle"
    # fluentd_image bundles its plugins (e.g. fluent-plugin-grafana-loki) via
    # Bundler in an isolated gemset (see its entrypoint.sh: `fluentd ...
    # --gemfile /fluentd/Gemfile`). Plain `gem install` is invisible to that
    # isolated gemset, so extra plugins are added to the same Gemfile and
    # bundle-installed into the same vendor path before starting fluentd.
    command: >-
      sh -c "
      for p in {{ fluentd_plugins | join(' ') }}; do
      bundle list --gemfile=/fluentd/Gemfile 2>/dev/null | grep -qi \"$$p\" || echo \"gem '$$p'\" >> /fluentd/Gemfile;
      done;
      bundle install --gemfile=/fluentd/Gemfile --path=/fluentd/vendor/bundle;
      exec fluentd -c /fluentd/etc/fluentd.conf -p /fluentd/plugins --gemfile /fluentd/Gemfile"
{% endif %}
{% if fluentd_plugins | length > 0 %}

volumes:
  fluentd_vendor_bundle: {}
{% endif %}
